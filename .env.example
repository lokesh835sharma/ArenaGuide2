# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# StadiumMate runs fully offline without any of these set: if GEMINI_API_KEY is
# absent, the app transparently falls back to a deterministic MockLLM.

# --- Google Gemini (optional) ---
# Leave blank to use the offline MockLLM. Provide a key to enable live phrasing.
GEMINI_API_KEY=
# Model id used for phrasing/translation only (it never invents facts).
GEMINI_MODEL=gemini-1.5-flash
# Hard cap on generated tokens (efficiency + cost control).
GEMINI_MAX_OUTPUT_TOKENS=256

# --- HTTP security ---
# JSON array of origins allowed by CORS. Default is same-origin localhost only.
ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# --- Rate limiting (per client IP, token bucket) on /api/assist ---
RATE_LIMIT_CAPACITY=30
RATE_LIMIT_REFILL_PER_SEC=0.5
